---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Tất cả bài viết" description="Danh sách tất cả bài viết trên blog">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Tất cả bài viết</h1>
  {posts.length === 0 ? (
    <p class="text-gray-500">Chưa có bài viết nào.</p>
  ) : (
    <div class="space-y-4">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id.replace(/\.[^.]+$/, '')}
        />
      ))}
    </div>
  )}
</BaseLayout>
